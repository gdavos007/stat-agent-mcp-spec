# This project does not automatically load .env files. Export these values in the
# launching shell or add them to the MCP client's environment configuration.

# Safe label returned to MCP clients. Do not put credentials in this value.
STAT_MCP_CONNECTION_NAME=demo_sqlite

# Local SQLite file path. Use a placeholder here; never commit a real sensitive path.
STAT_MCP_SQLITE_PATH=/path/to/demo.sqlite3

STAT_MCP_DEFAULT_ROW_LIMIT=1000
STAT_MCP_HARD_ROW_LIMIT=10000

# Required only by stat-agent-mcp-http. Generate a high-entropy value and store it
# as a sealed/private deployment variable; do not commit the generated value.
STAT_MCP_HTTP_BEARER_TOKEN=<generate-a-high-entropy-token>
