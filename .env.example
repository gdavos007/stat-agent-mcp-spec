# Safe label returned to MCP clients. Do not put credentials in this value.
STAT_MCP_CONNECTION_NAME=demo_sqlite

# Local SQLite file path. Use a placeholder here; never commit a real sensitive path.
STAT_MCP_SQLITE_PATH=/path/to/demo.sqlite3

STAT_MCP_DEFAULT_ROW_LIMIT=1000
STAT_MCP_HARD_ROW_LIMIT=10000

